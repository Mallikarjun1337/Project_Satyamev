# Demo Web App Environment Variables
# Copy this file to .env.development or .env.production and configure

# API Base URL - Backend verification service endpoint
# Production: Use your deployed API Gateway URL
# Development: Use local backend or deployed endpoint for testing
VITE_API_BASE_URL=https://0hkbdazey9.execute-api.us-east-1.amazonaws.com/api

# Enable fallback mode when API is unavailable
# true = Show demo data when API fails
# false = Show error messages only
VITE_ENABLE_FALLBACK=true

# API request timeout in milliseconds
# Recommended: 5000-10000 for text, 10000-15000 for images
VITE_API_TIMEOUT=5000

# Feature flags
VITE_ENABLE_IMAGE_UPLOAD=true
VITE_ENABLE_QUICK_DEMO=true
VITE_ENABLE_ANALYTICS=false

# UI Configuration
VITE_APP_TITLE=Satyamev Vijayate - Truth Verification
VITE_MAX_MESSAGE_LENGTH=1000
VITE_MAX_IMAGE_SIZE_MB=5
